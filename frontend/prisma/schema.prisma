generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int                 @id @default(autoincrement())
  email              String              @unique
  name               String?
  authId             String?             @unique
  avatar             String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @default(now()) @updatedAt
  role               Role                @default(PATIENT)
  city               String?
  latitude           Float?
  longitude          Float?
  region             String?
  age                Int?
  gender             Gender?
  province           String?
  barangay           String?
  birthday           DateTime?
  isOnboarded        Boolean             @default(false)
  district           String?
  address            String?
  privacyAcceptedAt  DateTime?
  privacyVersion     String?
  termsAcceptedAt    DateTime?
  termsVersion       String?
  approvalStatus     ApprovalStatus      @default(ACTIVE)
  approvedAt         DateTime?
  approvedBy         Int?
  approvalNotes      String?
  rejectedAt         DateTime?
  acknowledgedAlerts Alert[]             @relation("AlertAcknowledger")
  resolvedAlerts     Alert[]             @relation("AlertResolver")
  alertNotes         AlertNote[]         @relation("AlertNoteAuthor")
  chats              Chat[]
  diagnoses          Diagnosis[]
  diagnosisOverrides DiagnosisOverride[] @relation("OverrideClinicianRelation")

  @@index([latitude, longitude])
  @@index([region])
  @@index([province])
}

model Chat {
  id            Int             @id @default(autoincrement())
  chatId        String          @unique
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  userId        Int
  hasDiagnosis  Boolean         @default(false)
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  diagnosis     Diagnosis?
  messages      Message[]
  tempDiagnoses TempDiagnosis[]
}

model Message {
  id            Int            @id @default(autoincrement())
  content       String
  role          MessageRole
  createdAt     DateTime       @default(now())
  chatId        String
  type          MessageType    @default(SYMPTOMS)
  explanation   Explanation?
  chat          Chat           @relation(fields: [chatId], references: [chatId], onDelete: Cascade)
  tempDiagnosis TempDiagnosis?
}

model TempDiagnosis {
  id          Int      @id @default(autoincrement())
  confidence  Float
  uncertainty Float
  disease     Disease
  createdAt   DateTime @default(now())
  messageId   Int      @unique
  modelUsed   Model
  chatId      String
  symptoms    String
  cdss        Json?
  chat        Chat     @relation(fields: [chatId], references: [chatId], onDelete: Cascade)
  message     Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model Diagnosis {
  id              Int                @id @default(autoincrement())
  confidence      Float
  uncertainty     Float
  disease         Disease
  createdAt       DateTime           @default(now())
  chatId          String             @unique
  userId          Int
  modelUsed       Model
  symptoms        String
  city            String?
  latitude        Float?
  longitude       Float?
  region          String?
  province        String?
  barangay        String?
  district        String?
  cdss            Json?
  bmiAdvice       String?
  heightCm        Float?
  temperature     Float?
  temperatureUnit String?
  weightKg        Float?
  alerts          Alert[]
  chat            Chat               @relation(fields: [chatId], references: [chatId], onDelete: Cascade)
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  override        DiagnosisOverride?
  explanation     Explanation?

  @@index([createdAt])
  @@index([disease])
  @@index([disease, createdAt])
  @@index([userId])
}

model Explanation {
  id          Int        @id @default(autoincrement())
  createdAt   DateTime   @default(now())
  diagnosisId Int?       @unique
  tokens      String[]
  importances Float[]
  messageId   Int?       @unique
  diagnosis   Diagnosis? @relation(fields: [diagnosisId], references: [id], onDelete: Cascade)
  message     Message?   @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model DiagnosisOverride {
  id               Int       @id @default(autoincrement())
  diagnosisId      Int       @unique
  aiDisease        Disease
  aiConfidence     Float
  aiUncertainty    Float
  clinicianDisease Disease
  clinicianNotes   String?
  clinicianId      Int
  createdAt        DateTime  @default(now())
  clinician        User      @relation("OverrideClinicianRelation", fields: [clinicianId], references: [id], onDelete: Cascade)
  diagnosis        Diagnosis @relation(fields: [diagnosisId], references: [id], onDelete: Cascade)

  @@index([clinicianId])
  @@index([createdAt])
}

model Alert {
  id             Int           @id @default(autoincrement())
  type           AlertType
  severity       AlertSeverity
  status         AlertStatus   @default(NEW)
  diagnosisId    Int?
  reasonCodes    String[]
  message        String
  metadata       Json?
  createdAt      DateTime      @default(now())
  acknowledgedAt DateTime?
  acknowledgedBy Int?
  resolvedAt     DateTime?
  resolvedBy     Int?
  acknowledger   User?         @relation("AlertAcknowledger", fields: [acknowledgedBy], references: [id])
  diagnosis      Diagnosis?    @relation(fields: [diagnosisId], references: [id])
  resolver       User?         @relation("AlertResolver", fields: [resolvedBy], references: [id])
  notes          AlertNote[]
}

model AlertNote {
  id        Int      @id @default(autoincrement())
  alertId   Int
  authorId  Int
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  alert     Alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)
  author    User     @relation("AlertNoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)
}

model AllowedClinicianEmail {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())
}

model diagnosis_sessions {
  session_id       String @id
  chat_id          String
  initial_symptoms String
  base_probs       String
  current_probs    String
  disease          String
  confidence       Float
  uncertainty      Float
  top_diseases     String
  model_used       String
  lang             String @default("en")
  asked_questions  String @default("[]")
  evidence_texts   String @default("[]")
  created_at       Float
  updated_at       Float
  question_answers String @default("{}")
  initial_eig      Float?

  @@index([chat_id], map: "idx_diagnosis_sessions_chat_id")
  @@index([created_at], map: "idx_diagnosis_sessions_created_at")
}

enum Role {
  PATIENT
  CLINICIAN
  DEVELOPER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum MessageRole {
  USER
  AI
}

enum MessageType {
  SYMPTOMS
  ANSWER
  QUESTION
  DIAGNOSIS
  URGENT_WARNING
  ERROR
  INFO
}

enum Disease {
  DENGUE    @map("Dengue")
  PNEUMONIA @map("Pneumonia")
  TYPHOID   @map("Typhoid")
  IMPETIGO  @map("Impetigo")
  DIARRHEA  @map("Diarrhea")
  MEASLES   @map("Measles")
  INFLUENZA @map("Influenza")
}

enum Model {
  BIOCLINICAL_MODERNBERT @map("BioClinical-ModernBERT")
  ROBERTA_TAGALOG        @map("RoBERTa-Tagalog")
}

enum AlertType {
  ANOMALY
  LOW_CONFIDENCE
  HIGH_UNCERTAINTY
  OUTBREAK
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  NEW
  ACKNOWLEDGED
  DISMISSED
  RESOLVED
}

enum ApprovalStatus {
  PENDING_ADMIN_APPROVAL
  ACTIVE
  REJECTED
}
